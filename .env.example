# ── Flask ─────────────────────────────────────────────────────────────────────
SECRET_KEY=a3f8c2d19e7b4f0a6c2e8d1b3f7a9c0e4d6b2a8f1c3e5d7b9a0f2c4e6d8b0a2
DEBUG=false
HOST=0.0.0.0
PORT=5000

# Session/cookie hardening (set secure=true in HTTPS production)
SESSION_COOKIE_SECURE=true
REMEMBER_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Lax
PREFERRED_URL_SCHEME=https

# Trust X-Forwarded-* headers from Render/reverse proxies
TRUST_PROXY_HEADERS=true

# Optional persistent storage paths (Render disk example)
# DATA_DIR=/var/data/data
# UPLOAD_FOLDER=/var/data/audio

# ── Speech-to-Text (lightweight) ──────────────────────────────────────────────
# Uses Google Web Speech via SpeechRecognition (no local model download).
# Default language hint: en, hi, mr, es, fr, de, it, pt, ja, zh
STT_DEFAULT_LANG=en

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Download from Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_SECRETS_FILE=./client_secrets.json

# Allow HTTP during local development only. Keep 0 in production.
OAUTHLIB_INSECURE_TRANSPORT=0

# Must match EXACTLY one of the Authorised Redirect URIs in Google Cloud Console.
# Default uses 127.0.0.1 (what Flask binds to). Change to localhost if you
# registered localhost in the console instead.
GOOGLE_REDIRECT_URI=http://127.0.0.1:5000/login/google/callback

# ── Milestone 4: Security / RBAC ─────────────────────────────────────────────
# Comma-separated list of admin users.
ADMIN_EMAILS=admin@example.com

# Voice PIN required for secure send actions.
VOICE_ACTION_PIN=2468

# Optional security tuning.
PIN_MAX_ATTEMPTS=3
ACTION_CHALLENGE_TTL=300
ACTION_TOKEN_TTL=300
